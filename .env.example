# p95 Configuration

# Server
PORT=8080
HOST=0.0.0.0
DEBUG=true

# Database
DATABASE_URL=postgres://p95:p95@localhost:5432/p95?sslmode=disable

# Redis (optional)
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=your-super-secret-key-change-in-production

# Deployment mode: "self-hosted" or "cloud"
DEPLOYMENT_MODE=self-hosted

# Self-hosted admin credentials
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=changeme

# Cloud mode settings (only used when DEPLOYMENT_MODE=cloud)
# ENABLE_BILLING=true
# STRIPE_KEY=sk_test_xxx

# Metrics settings
METRICS_BATCH_SIZE=5000
METRICS_FLUSH_INTERVAL=1s

# Session settings
SESSION_DURATION=24h
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=168h
